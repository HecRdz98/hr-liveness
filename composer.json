{
    "name": "hr/liveness",
    "description": "Widget white-label de verificación de liveness facial para Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        { "name": "Héctor Rodríguez", "homepage": "https://github.com/HecRdz98" }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "HR\\Liveness\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": ["HR\\Liveness\\LivenessServiceProvider"]
        }
    },
    "minimum-stability": "stable"
}
